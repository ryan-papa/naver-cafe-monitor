---
/**
 * AppShell.astro — 어드민 전역 레이아웃 셸.
 * html > head(BaseHead) + body.mf-admin > Sidebar + (Topbar + main slot)
 */
import BaseHead from "../BaseHead.astro";
import Sidebar from "./Sidebar.astro";
import Topbar from "./Topbar.astro";
import "../../styles/tokens.css";
import "../../styles/globals.css";

interface Props {
  title?: string;
  description?: string;
  email?: string | undefined;
  activeRoute?: string;
  version?: string;
}

const {
  title = "Naver Cafe Monitor",
  description = "내부 어드민",
  email,
  activeRoute = Astro.url?.pathname ?? "",
  version = "0.0.1",
} = Astro.props;
---

<html lang="ko">
  <head>
    <BaseHead title={title} description={description} />
  </head>
  <body class="mf-admin">
    <div class="appshell">
      <Sidebar activeRoute={activeRoute} version={version} />
      <div class="appshell__body">
        <Topbar email={email} />
        <main class="appshell__main">
          <slot />
        </main>
      </div>
    </div>
  </body>
</html>

<style is:global>
  html,
  body {
    margin: 0;
    padding: 0;
    height: 100%;
  }
  body.mf-admin {
    min-height: 100dvh;
  }
  .appshell {
    display: flex;
    min-height: 100dvh;
    width: 100%;
    background: var(--bg);
    color: var(--fg);
  }
  .appshell__body {
    flex: 1;
    display: flex;
    flex-direction: column;
    min-width: 0;
  }
  .appshell__main {
    flex: 1;
    display: flex;
    flex-direction: column;
    overflow: auto;
  }
</style>
