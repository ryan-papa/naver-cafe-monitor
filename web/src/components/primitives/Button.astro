---
/** Button.astro — variant: default/primary/ghost/danger/subtle, size: sm/md/lg, icon/iconRight(IconName), active, disabled. */
import Icon, { type IconName } from "./Icon.astro";

type Variant = "default" | "primary" | "ghost" | "danger" | "subtle";
type Size = "sm" | "md" | "lg";

interface Props {
  variant?: Variant;
  size?: Size;
  icon?: IconName;
  iconRight?: IconName;
  active?: boolean;
  disabled?: boolean;
  type?: "button" | "submit" | "reset";
  id?: string;
  name?: string;
  value?: string;
  title?: string;
  "aria-label"?: string;
  "aria-pressed"?: boolean | "true" | "false";
  "aria-expanded"?: boolean | "true" | "false";
  "aria-controls"?: string;
  "data-testid"?: string;
  class?: string;
}

const {
  variant = "default",
  size = "md",
  icon,
  iconRight,
  active = false,
  disabled = false,
  type = "button",
  class: className,
  ...rest
} = Astro.props;

const sizeMap = {
  sm: { h: 24, px: 8, fs: 11, iconSize: 12 },
  md: { h: 28, px: 10, fs: 12, iconSize: 14 },
  lg: { h: 34, px: 14, fs: 13, iconSize: 16 },
} as const;

const s = sizeMap[size];
const classes = [
  "btn",
  `btn--${variant}`,
  active ? "is-active" : "",
  className ?? "",
]
  .filter(Boolean)
  .join(" ");
---
<button
  type={type}
  class={classes}
  disabled={disabled}
  style={`height:${s.h}px;padding:0 ${s.px}px;font-size:${s.fs}px;`}
  {...rest}
>
  {icon && <Icon name={icon} size={s.iconSize} />}
  <slot />
  {iconRight && <Icon name={iconRight} size={s.iconSize} />}
</button>

<style>
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    border-radius: var(--r-4);
    font-weight: 500;
    white-space: nowrap;
    cursor: pointer;
    transition: background 0.12s ease, border-color 0.12s ease;
    font-family: inherit;
    line-height: 1;
  }
  .btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }
  .btn--default {
    background: var(--bg-elev);
    color: var(--fg);
    border: 1px solid var(--border);
  }
  .btn--primary {
    background: var(--accent);
    color: #fff;
    border: 1px solid var(--accent);
  }
  .btn--ghost {
    background: transparent;
    color: var(--fg-muted);
    border: 1px solid transparent;
  }
  .btn--danger {
    background: var(--bg-elev);
    color: var(--danger);
    border: 1px solid var(--danger-border);
  }
  .btn--subtle {
    background: var(--bg-soft);
    color: var(--fg);
    border: 1px solid var(--border);
  }
  .btn.is-active {
    background: var(--bg-hover);
  }
  .btn--default:not(:disabled):hover,
  .btn--subtle:not(:disabled):hover,
  .btn--ghost:not(:disabled):hover {
    background: var(--bg-hover);
  }
  .btn--primary:not(:disabled):hover {
    background: var(--accent-hover);
    border-color: var(--accent-hover);
  }
  .btn--danger:not(:disabled):hover {
    background: var(--danger-soft);
  }
</style>
