---
/** Pagination.astro — museum-finder admin pagination 포팅. props: page(0-base), pageSize, totalElements, totalPages. URL 쿼리(page/size) 갱신. */
import Button from "./Button.astro";
import Select from "./Select.astro";

interface Props {
  page: number;
  pageSize: number;
  totalElements: number;
  totalPages: number;
  itemsOnPage?: number;
  pageParam?: string;
  sizeParam?: string;
  class?: string;
}

const {
  page,
  pageSize,
  totalElements,
  totalPages,
  itemsOnPage,
  pageParam = "page",
  sizeParam = "size",
  class: className,
} = Astro.props;

const pageUI = page + 1;
const startN = totalElements === 0 ? 0 : page * pageSize + 1;
const shown = itemsOnPage ?? Math.min(pageSize, Math.max(0, totalElements - page * pageSize));
const endN = Math.min(page * pageSize + shown, totalElements);
const atFirst = page <= 0;
const atLast = totalPages === 0 || page + 1 >= totalPages;
---
<div
  class={`pagination${className ? " " + className : ""}`}
  data-page-param={pageParam}
  data-size-param={sizeParam}
  data-total-pages={totalPages}
  data-current-page={page}
>
  <span class="pagination__count">
    {totalElements === 0
      ? "0 / 0"
      : `${startN.toLocaleString()}–${endN.toLocaleString()} / ${totalElements.toLocaleString()}`}
  </span>
  <Select
    size="sm"
    value={String(pageSize)}
    aria-label="페이지당 표시 개수"
    class="pagination__size"
    options={[
      { value: "10", label: "10개씩" },
      { value: "20", label: "20개씩" },
      { value: "50", label: "50개씩" },
      { value: "100", label: "100개씩" },
    ]}
  />
  <Button
    size="sm"
    variant="ghost"
    disabled={atFirst}
    aria-label="맨 앞 페이지"
    data-pagination-action="first"
  >«</Button>
  <Button
    size="sm"
    variant="ghost"
    icon="chevL"
    disabled={atFirst}
    aria-label="이전 페이지"
    data-pagination-action="prev"
  />
  <span class="pagination__cursor">
    {pageUI.toLocaleString()} / {Math.max(totalPages, 1).toLocaleString()}
  </span>
  <Button
    size="sm"
    variant="ghost"
    icon="chevR"
    disabled={atLast}
    aria-label="다음 페이지"
    data-pagination-action="next"
  />
  <Button
    size="sm"
    variant="ghost"
    disabled={atLast}
    aria-label="맨 끝 페이지"
    data-pagination-action="last"
  >»</Button>
</div>

<script>
  type Action = "first" | "prev" | "next" | "last";

  function updateUrl(params: Record<string, string>) {
    const url = new URL(window.location.href);
    for (const [k, v] of Object.entries(params)) {
      url.searchParams.set(k, v);
    }
    window.location.assign(url.toString());
  }

  document.querySelectorAll<HTMLElement>(".pagination").forEach((root) => {
    const pageParam = root.dataset.pageParam ?? "page";
    const sizeParam = root.dataset.sizeParam ?? "size";
    const totalPages = Number(root.dataset.totalPages ?? "0");
    const current = Number(root.dataset.currentPage ?? "0");

    root.querySelectorAll<HTMLButtonElement>("[data-pagination-action]").forEach((btn) => {
      btn.addEventListener("click", () => {
        if (btn.disabled) return;
        const action = btn.dataset.paginationAction as Action;
        let next = current;
        if (action === "first") next = 0;
        else if (action === "prev") next = Math.max(0, current - 1);
        else if (action === "next") next = current + 1;
        else if (action === "last") next = Math.max(0, totalPages - 1);
        updateUrl({ [pageParam]: String(next) });
      });
    });

    const sizeSelect = root.querySelector<HTMLSelectElement>(".pagination__size");
    sizeSelect?.addEventListener("change", () => {
      updateUrl({ [sizeParam]: sizeSelect.value, [pageParam]: "0" });
    });
  });
</script>

<style>
  .pagination {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 12px;
    color: var(--fg-muted);
  }
  .pagination__count {
    font-variant-numeric: tabular-nums;
  }
  .pagination__cursor {
    font-variant-numeric: tabular-nums;
    min-width: 64px;
    text-align: center;
  }
</style>
