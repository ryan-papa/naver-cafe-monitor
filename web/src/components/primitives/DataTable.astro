---
/** DataTable.astro — columns[]+rows[] 기반. columns[i].render(row)는 HTML 문자열. caption은 sr-only. */
export type Column<T = Record<string, unknown>> = {
  key: string;
  label: string;
  align?: "left" | "right";
  /** HTML 문자열 반환. 호출자가 이스케이프 책임. */
  render: (row: T) => string;
};

interface Props {
  columns: Column[];
  rows: Record<string, unknown>[];
  emptyText: string;
  caption?: string;
  class?: string;
}

const { columns, rows, emptyText, caption, class: className } = Astro.props;
---
{rows.length === 0 ? (
  <div role="status" class={`datatable-empty${className ? " " + className : ""}`}>
    {emptyText}
  </div>
) : (
  <table class={`mf-table${className ? " " + className : ""}`}>
    {caption && <caption class="sr-only">{caption}</caption>}
    <thead>
      <tr>
        {columns.map((c) => (
          <th scope="col" style={`text-align:${c.align ?? "left"};`}>{c.label}</th>
        ))}
      </tr>
    </thead>
    <tbody>
      {rows.map((r, i) => (
        <tr class={i % 2 ? "row-alt" : "row-base"}>
          {columns.map((c) => (
            <td
              style={`text-align:${c.align ?? "left"};`}
              set:html={c.render(r)}
            />
          ))}
        </tr>
      ))}
    </tbody>
  </table>
)}

<style>
  .datatable-empty {
    padding: 24px;
    text-align: center;
    color: var(--fg-faint);
    font-size: 13px;
    border: 1px dashed var(--border);
    border-radius: var(--r-4);
  }
  .mf-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 13px;
  }
  .mf-table thead tr {
    color: var(--fg-faint);
    font-size: 12px;
    letter-spacing: 0.02em;
    border-bottom: 1px solid var(--border);
  }
  .mf-table th {
    padding: 8px;
    font-weight: 500;
  }
  .mf-table td {
    padding: 7px 8px;
    color: var(--fg);
    vertical-align: top;
  }
  .mf-table tbody tr {
    border-bottom: 1px solid var(--divider);
  }
  .mf-table tbody tr.row-base {
    background: var(--bg-table-row);
  }
  .mf-table tbody tr.row-alt {
    background: var(--bg-table-alt);
  }
  .mf-table tbody tr:hover {
    background: var(--bg-hover);
  }
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>
