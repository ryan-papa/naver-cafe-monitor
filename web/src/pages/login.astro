---
/**
 * /login — 관리자 로그인.
 * museum-finder 토큰 기반 카드 리디자인. 폼 로직·API·에러처리는 기존과 동일.
 */
import BaseHead from "../components/BaseHead.astro";
import Button from "../components/primitives/Button.astro";
import Input from "../components/primitives/Input.astro";
import "../styles/tokens.css";
import "../styles/globals.css";
---

<html lang="ko">
  <head>
    <BaseHead title="로그인 · 카페 모니터" description="관리자 로그인" />
  </head>
  <body class="mf-admin auth">
    <main class="auth__shell">
      <section class="auth__card" aria-labelledby="login-title">
        <header class="auth__brand">
          <div class="auth__logo" aria-hidden="true">NC</div>
          <div class="auth__brand-text">
            <div class="auth__brand-title">Naver Cafe Monitor</div>
            <div class="auth__brand-sub">Admin</div>
          </div>
        </header>

        <h1 id="login-title" class="auth__title">로그인</h1>
        <p class="auth__sub">이메일과 비밀번호를 입력하세요.</p>

        <div id="err" class="alert alert--danger" role="alert" hidden></div>

        <form id="login-form" novalidate>
          <div id="creds-step" class="auth__fields">
            <div class="auth__field">
              <label for="email">이메일</label>
              <Input id="email" type="email" required autocomplete="email" />
            </div>
            <div class="auth__field">
              <label for="password">비밀번호</label>
              <Input id="password" type="password" required autocomplete="current-password" />
            </div>
          </div>

          <div id="totp-step" class="auth__fields auth__fields--totp" hidden>
            <div class="auth__field">
              <label for="totp">인증 앱 코드</label>
              <Input
                id="totp"
                type="text"
                inputmode="numeric"
                pattern="[0-9]*"
                maxlength={6}
                autocomplete="one-time-code"
              />
              <p class="auth__hint">Google Authenticator 등에 표시된 6자리 코드를 입력하세요.</p>
            </div>
          </div>

          <div class="auth__submit">
            <Button id="submit" type="submit" variant="primary" size="lg">로그인</Button>
          </div>
        </form>

        <p class="auth__foot">
          계정이 없으신가요? <a href="/signup">회원가입</a>
        </p>
      </section>
    </main>

    <style>
      body.auth {
        background: var(--bg-soft);
        min-height: 100dvh;
        margin: 0;
      }
      .auth__shell {
        min-height: 100dvh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 32px 16px;
      }
      .auth__card {
        width: 100%;
        max-width: 400px;
        background: var(--bg-elev);
        border: 1px solid var(--border);
        border-radius: var(--r-8);
        box-shadow: var(--shadow-md);
        padding: 32px;
      }
      .auth__brand {
        display: flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 20px;
      }
      .auth__logo {
        width: 22px;
        height: 22px;
        border-radius: var(--r-4);
        background: var(--fg);
        color: var(--bg);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 12px;
        font-weight: 700;
        letter-spacing: -0.02em;
        font-family: var(--font-mono);
        flex-shrink: 0;
      }
      .auth__brand-text { display: flex; flex-direction: column; line-height: 1.15; }
      .auth__brand-title { font-size: var(--fs-13); font-weight: 600; color: var(--fg); }
      .auth__brand-sub { font-size: var(--fs-11); color: var(--fg-faint); }
      .auth__title {
        font-size: var(--fs-18);
        font-weight: 600;
        color: var(--fg);
        margin: 0 0 4px 0;
        letter-spacing: -0.01em;
      }
      .auth__sub {
        font-size: var(--fs-13);
        color: var(--fg-muted);
        margin: 0 0 20px 0;
      }
      .auth__fields {
        display: flex;
        flex-direction: column;
        gap: 12px;
      }
      .auth__fields--totp { margin-top: 12px; }
      .auth__field { display: flex; flex-direction: column; gap: 4px; }
      .auth__field label {
        font-size: var(--fs-12);
        font-weight: 500;
        color: var(--fg-muted);
      }
      .auth__hint {
        font-size: var(--fs-12);
        color: var(--fg-faint);
        margin: 4px 0 0 0;
      }
      .auth__submit { margin-top: 16px; display: flex; flex-direction: column; }
      .auth__submit :global(.btn) { width: 100%; justify-content: center; }
      .auth__foot {
        text-align: center;
        font-size: var(--fs-13);
        color: var(--fg-muted);
        margin: 18px 0 0 0;
      }
      .auth__foot a {
        color: var(--accent-fg);
        font-weight: 600;
        text-decoration: none;
      }
      .auth__foot a:hover { text-decoration: underline; }
      .alert {
        padding: 10px 12px;
        border-radius: var(--r-6);
        font-size: var(--fs-13);
        border: 1px solid transparent;
        margin-bottom: 12px;
      }
      .alert--danger {
        background: var(--danger-soft);
        color: var(--danger);
        border-color: var(--danger-border);
      }
      @media (max-width: 480px) {
        .auth__card { padding: 24px; box-shadow: none; }
      }
    </style>

    <script>
      import { fetchPublicKey, encryptField } from '../lib/auth-client';

      const form = document.getElementById('login-form') as HTMLFormElement;
      const errBox = document.getElementById('err') as HTMLDivElement;
      const emailInput = document.getElementById('email') as HTMLInputElement;
      const pwInput = document.getElementById('password') as HTMLInputElement;
      const totpInput = document.getElementById('totp') as HTMLInputElement;
      const totpStep = document.getElementById('totp-step') as HTMLDivElement;
      const submitBtn = document.getElementById('submit') as HTMLButtonElement;
      const next = new URL(window.location.href).searchParams.get('next') || '/admin';

      let cachedKey: CryptoKey | null = null;
      async function getKey() {
        if (!cachedKey) cachedKey = await fetchPublicKey();
        return cachedKey;
      }

      function showErr(msg: string) {
        errBox.textContent = msg;
        errBox.hidden = false;
      }
      function clearErr() {
        errBox.hidden = true;
        errBox.textContent = '';
      }

      const ERROR_MSG: Record<string, string> = {
        invalid_credentials: '이메일 또는 비밀번호가 올바르지 않습니다.',
        account_locked: '로그인 실패가 반복되어 15분간 잠겼습니다. 잠시 후 다시 시도하세요.',
        ip_rate_limited: '요청이 너무 많습니다. 15분 뒤 다시 시도하세요.',
        account_rate_limited: '로그인 시도가 너무 많습니다. 15분 뒤 다시 시도하세요.',
        totp_required: '2단계 인증 코드가 필요합니다.',
        totp_invalid: '인증 코드가 올바르지 않습니다.',
      };

      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        clearErr();
        submitBtn.disabled = true;
        submitBtn.textContent = '처리 중…';
        try {
          const pub = await getKey();
          const body: Record<string, string> = {
            email_enc: await encryptField(pub, emailInput.value.trim()),
            password_enc: await encryptField(pub, pwInput.value),
          };
          if (!totpStep.hidden) {
            body.totp_code = totpInput.value.trim();
          }
          const r = await fetch('/api/auth/login', {
            method: 'POST',
            headers: { 'content-type': 'application/json' },
            credentials: 'include',
            body: JSON.stringify(body),
          });
          if (r.ok) {
            window.location.assign(next);
            return;
          }
          const data = await r.json().catch(() => ({}));
          const code = data.detail || 'unknown';
          if (code === 'totp_required' && totpStep.hidden) {
            totpStep.hidden = false;
            totpInput.focus();
            return;
          }
          showErr(ERROR_MSG[code] || '로그인에 실패했습니다. (' + code + ')');
        } catch (err) {
          console.error(err);
          showErr('네트워크 오류가 발생했습니다.');
        } finally {
          submitBtn.disabled = false;
          submitBtn.textContent = '로그인';
        }
      });
    </script>
  </body>
</html>
