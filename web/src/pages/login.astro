---
/**
 * /login — 관리자 로그인 진입점.
 *
 * 화면 선택지를 보여주지 않고 인증 상태에 따라 즉시 이동한다.
 */
const API_BASE =
  import.meta.env.INTERNAL_API_BASE || process.env.INTERNAL_API_BASE || "http://127.0.0.1:8000";
const cookie = Astro.request.headers.get("cookie") ?? "";

async function isAdminSession(): Promise<boolean> {
  try {
    const r = await fetch(`${API_BASE}/api/auth/me`, {
      headers: cookie ? { cookie } : {},
    });
    if (!r.ok) return false;
    const me = (await r.json()) as { is_admin?: boolean };
    return me.is_admin === true;
  } catch {
    return false;
  }
}

if (await isAdminSession()) {
  return Astro.redirect("/admin/posts", 302);
}

return Astro.redirect("/oauth2/authorization/google", 302);
---
