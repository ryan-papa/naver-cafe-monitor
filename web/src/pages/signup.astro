---
---

<html lang="ko">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>회원가입 · 카페 모니터</title>
		<link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />
		<link href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard/dist/web/static/pretendard-dynamic-subset.min.css" rel="stylesheet" />
		<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css" />
		<style>
			:root{--color-primary:#2e8555;--color-primary-light:#e6f6ed;--color-danger:#e3342f;--color-danger-light:#fef2f2;--color-warning:#e67e22;--color-warning-light:#fef9f0;--bg-main:#f6f8fa;--bg-surface:#ffffff;--border:#e3e8ee;--text-primary:#1c1e21;--text-secondary:#606770;--shadow:0 4px 12px rgba(0,0,0,0.06);--radius:16px}
			*{box-sizing:border-box;margin:0;padding:0}
			body{font-family:'Pretendard Variable',Pretendard,-apple-system,system-ui,sans-serif;background:var(--bg-main);color:var(--text-primary);min-height:100vh;display:flex;align-items:center;justify-content:center;padding:24px}
			.card{background:var(--bg-surface);border:1px solid var(--border);border-radius:var(--radius);padding:36px;box-shadow:var(--shadow);max-width:460px;width:100%}
			.brand{display:flex;align-items:center;gap:10px;margin-bottom:20px;justify-content:center}
			.brand-icon{width:40px;height:40px;border-radius:10px;background:var(--color-primary);color:#fff;display:flex;align-items:center;justify-content:center;font-size:1.2rem}
			.steps{display:flex;gap:4px;margin-bottom:24px}
			.step{flex:1;height:4px;border-radius:2px;background:var(--border)}
			.step.active{background:var(--color-primary)}
			h1{font-size:1.4rem;font-weight:800;letter-spacing:-0.02em;text-align:center;margin-bottom:4px}
			.sub{font-size:0.88rem;color:var(--text-secondary);text-align:center;margin-bottom:24px}
			label{display:block;font-size:0.82rem;font-weight:600;margin-bottom:6px;color:var(--text-secondary)}
			input{width:100%;padding:12px 14px;border:1px solid var(--border);border-radius:10px;font-size:0.95rem;font-family:inherit;background:#fff;margin-bottom:12px}
			input:focus{outline:none;border-color:var(--color-primary);box-shadow:0 0 0 3px rgba(46,133,85,0.1)}
			.hint{font-size:0.76rem;color:var(--text-secondary);margin-top:-6px;margin-bottom:12px}
			.btn{width:100%;padding:12px;border:none;border-radius:10px;font-size:0.95rem;font-weight:700;cursor:pointer;font-family:inherit;background:var(--color-primary);color:#fff;transition:opacity 0.15s}
			.btn:hover{opacity:0.92}.btn:disabled{opacity:0.5;cursor:not-allowed}
			.btn-ghost{background:transparent;color:var(--text-secondary);border:1px solid var(--border)}
			.err{background:var(--color-danger-light);color:var(--color-danger);border-radius:8px;padding:10px 14px;font-size:0.85rem;margin-bottom:12px;display:none}
			.err.show{display:block}
			.qr{display:flex;justify-content:center;margin:16px 0;padding:20px;background:#fff;border:1px solid var(--border);border-radius:12px}
			.qr img{width:200px;height:200px}
			.codes{background:var(--color-warning-light);border:1px solid var(--color-warning);border-radius:10px;padding:14px;margin:12px 0}
			.codes-title{display:flex;align-items:center;gap:6px;font-weight:700;font-size:0.85rem;color:var(--color-warning);margin-bottom:8px}
			.codes ul{list-style:none;columns:2;gap:4px;font-family:'SF Mono',Menlo,monospace;font-size:0.82rem;color:var(--text-primary)}
			.codes li{padding:2px 0}
			.nav{text-align:center;font-size:0.88rem;color:var(--text-secondary);margin-top:18px}
			.nav a{color:var(--color-primary);font-weight:700;text-decoration:none}
			.step-box{display:none}
			.step-box.active{display:block}
		</style>
	</head>
	<body>
		<main class="card">
			<div class="brand">
				<span class="brand-icon"><i class="bi bi-clipboard2-data"></i></span>
				<span style="font-weight:800">카페 모니터</span>
			</div>
			<div class="steps">
				<div class="step active" id="s1"></div>
				<div class="step" id="s2"></div>
				<div class="step" id="s3"></div>
			</div>
			<div id="err" class="err"></div>

			<!-- Step 1 -->
			<section id="step-1" class="step-box active">
				<h1>계정 만들기</h1>
				<p class="sub">이메일·이름·비밀번호를 입력하세요.</p>
				<label>이메일</label>
				<input id="email" type="email" autocomplete="email" />
				<label>이름</label>
				<input id="name" type="text" maxlength="100" autocomplete="name" />
				<label>비밀번호</label>
				<input id="pw" type="password" autocomplete="new-password" />
				<p class="hint">최소 10자, 영문·숫자·특수문자 포함</p>
				<button id="next1" class="btn">다음</button>
				<p class="nav">이미 계정이 있나요? <a href="/login">로그인</a></p>
			</section>

			<!-- Step 2 -->
			<section id="step-2" class="step-box">
				<h1>2단계 인증 설정</h1>
				<p class="sub">Google Authenticator 등으로 QR을 스캔하세요.</p>
				<div class="qr"><img id="qr-img" alt="TOTP QR" /></div>
				<div class="codes">
					<div class="codes-title"><i class="bi bi-shield-lock"></i> 백업 코드 (안전한 곳에 보관)</div>
					<ul id="codes"></ul>
				</div>
				<button id="next2" class="btn">QR 스캔 완료, 다음</button>
			</section>

			<!-- Step 3 -->
			<section id="step-3" class="step-box">
				<h1>인증 코드 확인</h1>
				<p class="sub">앱에 표시된 6자리 코드를 입력해 가입을 마무리하세요.</p>
				<label>인증 코드</label>
				<input id="totp" type="text" inputmode="numeric" maxlength="6" autocomplete="one-time-code" />
				<button id="confirm" class="btn">회원가입 완료</button>
			</section>
		</main>

		<script>
			import { fetchPublicKey, encryptField } from '../lib/auth-client';

			const errBox = document.getElementById('err') as HTMLDivElement;
			const boxes = [1, 2, 3].map((i) => document.getElementById('step-' + i) as HTMLElement);
			const stepsBar = [1, 2, 3].map((i) => document.getElementById('s' + i) as HTMLElement);

			function go(n: number) {
				boxes.forEach((b, i) => b.classList.toggle('active', i === n - 1));
				stepsBar.forEach((b, i) => b.classList.toggle('active', i <= n - 1));
				clearErr();
			}
			function showErr(msg: string) {
				errBox.textContent = msg;
				errBox.classList.add('show');
			}
			function clearErr() {
				errBox.classList.remove('show');
				errBox.textContent = '';
			}

			const ERR: Record<string, string> = {
				email_invalid: '올바른 이메일 형식이 아닙니다.',
				name_invalid: '이름을 확인해주세요.',
				email_exists: '이미 가입된 이메일입니다.',
				password_too_short: '비밀번호는 최소 10자 이상이어야 합니다.',
				password_needs_letter: '비밀번호에 영문을 포함하세요.',
				password_needs_digit: '비밀번호에 숫자를 포함하세요.',
				password_needs_symbol: '비밀번호에 특수문자를 포함하세요.',
				pending_invalid: '가입 세션이 만료됐습니다. 처음부터 다시 시도하세요.',
				totp_invalid: '인증 코드가 올바르지 않습니다.',
				already_confirmed: '이미 인증이 완료된 계정입니다.',
			};

			let pendingToken = '';
			let cachedKey: CryptoKey | null = null;
			async function getKey() {
				if (!cachedKey) cachedKey = await fetchPublicKey();
				return cachedKey;
			}

			(document.getElementById('next1') as HTMLButtonElement).addEventListener('click', async (e) => {
				e.preventDefault();
				clearErr();
				const email = (document.getElementById('email') as HTMLInputElement).value.trim();
				const name = (document.getElementById('name') as HTMLInputElement).value.trim();
				const pw = (document.getElementById('pw') as HTMLInputElement).value;
				if (!email || !name || !pw) {
					showErr('모든 필드를 입력하세요.');
					return;
				}
				try {
					const pub = await getKey();
					const r = await fetch('/api/auth/signup', {
						method: 'POST',
						headers: { 'content-type': 'application/json' },
						credentials: 'include',
						body: JSON.stringify({
							email_enc: await encryptField(pub, email),
							name_enc: await encryptField(pub, name),
							password_enc: await encryptField(pub, pw),
						}),
					});
					if (!r.ok) {
						const d = await r.json().catch(() => ({}));
						showErr(ERR[d.detail] || '가입 실패 (' + d.detail + ')');
						return;
					}
					const data = await r.json();
					pendingToken = data.pending_token;
					const qrImg = document.getElementById('qr-img') as HTMLImageElement;
					qrImg.src = `https://api.qrserver.com/v1/create-qr-code/?size=200x200&data=${encodeURIComponent(data.otpauth_url)}`;
					const ul = document.getElementById('codes') as HTMLUListElement;
					ul.innerHTML = '';
					for (const c of data.backup_codes) {
						const li = document.createElement('li');
						li.textContent = c;
						ul.appendChild(li);
					}
					go(2);
				} catch (err) {
					console.error(err);
					showErr('네트워크 오류');
				}
			});

			(document.getElementById('next2') as HTMLButtonElement).addEventListener('click', () => go(3));

			(document.getElementById('confirm') as HTMLButtonElement).addEventListener('click', async (e) => {
				e.preventDefault();
				clearErr();
				const code = (document.getElementById('totp') as HTMLInputElement).value.trim();
				if (code.length < 6) {
					showErr('6자리 코드를 입력하세요.');
					return;
				}
				const r = await fetch('/api/auth/signup/confirm', {
					method: 'POST',
					headers: { 'content-type': 'application/json' },
					credentials: 'include',
					body: JSON.stringify({ pending_token: pendingToken, totp_code: code }),
				});
				if (!r.ok) {
					const d = await r.json().catch(() => ({}));
					showErr(ERR[d.detail] || '실패 (' + d.detail + ')');
					return;
				}
				window.location.assign('/');
			});
		</script>
	</body>
</html>
