---
/**
 * /signup — 단일 단계 회원가입 (계정 생성 즉시 자동 로그인).
 */
import BaseHead from "../components/BaseHead.astro";
import Button from "../components/primitives/Button.astro";
import Input from "../components/primitives/Input.astro";
import "../styles/tokens.css";
import "../styles/globals.css";
---

<html lang="ko">
  <head>
    <BaseHead title="회원가입 · 카페 모니터" description="관리자 계정 가입" />
  </head>
  <body class="mf-admin auth">
    <main class="auth__shell">
      <section class="auth__card" aria-labelledby="signup-title">
        <header class="auth__brand">
          <div class="auth__logo" aria-hidden="true">NC</div>
          <div class="auth__brand-text">
            <div class="auth__brand-title">Naver Cafe Monitor</div>
            <div class="auth__brand-sub">Admin</div>
          </div>
        </header>

        <h1 id="signup-title" class="auth__title">계정 만들기</h1>
        <p class="auth__sub">이메일·이름·비밀번호를 입력하세요.</p>

        <div id="err" class="alert alert--danger" role="alert" hidden></div>

        <form id="signup-form" novalidate>
          <div class="auth__fields">
            <div class="auth__field">
              <label for="email">이메일</label>
              <Input id="email" type="email" autocomplete="email" />
            </div>
            <div class="auth__field">
              <label for="name">이름</label>
              <Input id="name" type="text" maxlength={100} autocomplete="name" />
            </div>
            <div class="auth__field">
              <label for="pw">비밀번호</label>
              <Input id="pw" type="password" autocomplete="new-password" />
              <p class="auth__hint">최소 10자, 영문·숫자·특수문자 포함</p>
            </div>
          </div>
          <div class="auth__submit">
            <Button id="submit" type="submit" variant="primary" size="lg">가입 완료</Button>
          </div>
        </form>

        <p class="auth__foot">
          이미 계정이 있나요? <a href="/login">로그인</a>
        </p>
      </section>
    </main>

    <style>
      body.auth {
        background: var(--bg-soft);
        min-height: 100dvh;
        margin: 0;
      }
      .auth__shell {
        min-height: 100dvh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 32px 16px;
      }
      .auth__card {
        width: 100%;
        max-width: 400px;
        background: var(--bg-elev);
        border: 1px solid var(--border);
        border-radius: var(--r-8);
        box-shadow: var(--shadow-md);
        padding: 32px;
      }
      .auth__brand {
        display: flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 16px;
      }
      .auth__logo {
        width: 22px;
        height: 22px;
        border-radius: var(--r-4);
        background: var(--fg);
        color: var(--bg);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 12px;
        font-weight: 700;
        letter-spacing: -0.02em;
        font-family: var(--font-mono);
        flex-shrink: 0;
      }
      .auth__brand-text { display: flex; flex-direction: column; line-height: 1.15; }
      .auth__brand-title { font-size: var(--fs-13); font-weight: 600; color: var(--fg); }
      .auth__brand-sub { font-size: var(--fs-11); color: var(--fg-faint); }

      .auth__title {
        font-size: var(--fs-18);
        font-weight: 600;
        color: var(--fg);
        margin: 0 0 4px 0;
        letter-spacing: -0.01em;
      }
      .auth__sub {
        font-size: var(--fs-13);
        color: var(--fg-muted);
        margin: 0 0 16px 0;
      }
      .auth__fields { display: flex; flex-direction: column; gap: 12px; }
      .auth__field { display: flex; flex-direction: column; gap: 4px; }
      .auth__field label {
        font-size: var(--fs-12);
        font-weight: 500;
        color: var(--fg-muted);
      }
      .auth__hint {
        font-size: var(--fs-12);
        color: var(--fg-faint);
        margin: 4px 0 0 0;
      }
      .auth__submit { margin-top: 16px; display: flex; flex-direction: column; }
      .auth__submit :global(.btn) { width: 100%; justify-content: center; }
      .auth__foot {
        text-align: center;
        font-size: var(--fs-13);
        color: var(--fg-muted);
        margin: 18px 0 0 0;
      }
      .auth__foot a {
        color: var(--accent-fg);
        font-weight: 600;
        text-decoration: none;
      }
      .auth__foot a:hover { text-decoration: underline; }

      .alert {
        padding: 10px 12px;
        border-radius: var(--r-6);
        font-size: var(--fs-13);
        border: 1px solid transparent;
        margin-bottom: 12px;
      }
      .alert--danger {
        background: var(--danger-soft);
        color: var(--danger);
        border-color: var(--danger-border);
      }
      @media (max-width: 480px) {
        .auth__card { padding: 24px; box-shadow: none; }
      }
    </style>

    <script>
      import { fetchPublicKey, encryptField } from '../lib/auth-client';

      const form = document.getElementById('signup-form') as HTMLFormElement;
      const errBox = document.getElementById('err') as HTMLDivElement;
      const submitBtn = document.getElementById('submit') as HTMLButtonElement;

      function showErr(msg: string) {
        errBox.textContent = msg;
        errBox.hidden = false;
      }
      function clearErr() {
        errBox.hidden = true;
        errBox.textContent = '';
      }

      const ERR: Record<string, string> = {
        email_invalid: '올바른 이메일 형식이 아닙니다.',
        name_invalid: '이름을 확인해주세요.',
        email_exists: '이미 가입된 이메일입니다.',
        password_too_short: '비밀번호는 최소 10자 이상이어야 합니다.',
        password_needs_letter: '비밀번호에 영문을 포함하세요.',
        password_needs_digit: '비밀번호에 숫자를 포함하세요.',
        password_needs_symbol: '비밀번호에 특수문자를 포함하세요.',
      };

      let cachedKey: CryptoKey | null = null;
      async function getKey() {
        if (!cachedKey) cachedKey = await fetchPublicKey();
        return cachedKey;
      }

      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        clearErr();
        submitBtn.disabled = true;
        submitBtn.textContent = '처리 중…';
        const email = (document.getElementById('email') as HTMLInputElement).value.trim();
        const name = (document.getElementById('name') as HTMLInputElement).value.trim();
        const pw = (document.getElementById('pw') as HTMLInputElement).value;
        if (!email || !name || !pw) {
          showErr('모든 필드를 입력하세요.');
          submitBtn.disabled = false;
          submitBtn.textContent = '가입 완료';
          return;
        }
        try {
          const pub = await getKey();
          const r = await fetch('/api/auth/signup', {
            method: 'POST',
            headers: { 'content-type': 'application/json' },
            credentials: 'include',
            body: JSON.stringify({
              email_enc: await encryptField(pub, email),
              name_enc: await encryptField(pub, name),
              password_enc: await encryptField(pub, pw),
            }),
          });
          if (!r.ok) {
            const d = await r.json().catch(() => ({}));
            showErr(ERR[d.detail] || '가입 실패 (' + d.detail + ')');
            return;
          }
          window.location.assign('/admin');
        } catch (err) {
          console.error(err);
          showErr('네트워크 오류가 발생했습니다.');
        } finally {
          submitBtn.disabled = false;
          submitBtn.textContent = '가입 완료';
        }
      });
    </script>
  </body>
</html>
