---
interface Props {
	code: string;
	title: string;
	message: string;
	icon: string;
	accent?: 'danger' | 'warning' | 'info' | 'primary';
}
const { code, title, message, icon, accent = 'danger' } = Astro.props;
---

<html lang="ko">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>{code} · 카페 모니터</title>
		<link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />
		<link
			href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard/dist/web/static/pretendard-dynamic-subset.min.css"
			rel="stylesheet"
		/>
		<link
			rel="stylesheet"
			href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css"
		/>
		<style>
			:root {
				--color-primary: #2e8555;
				--color-primary-light: #e6f6ed;
				--color-danger: #e3342f;
				--color-danger-light: #fef2f2;
				--color-warning: #e67e22;
				--color-warning-light: #fef9f0;
				--color-info: #3578e5;
				--color-info-light: #eef4fd;
				--bg-main: #f6f8fa;
				--bg-surface: #ffffff;
				--border: #e3e8ee;
				--text-primary: #1c1e21;
				--text-secondary: #606770;
				--shadow: 0 4px 12px rgba(0, 0, 0, 0.06);
				--radius: 16px;
			}
			* { box-sizing: border-box; margin: 0; padding: 0; }
			body {
				font-family: 'Pretendard Variable', Pretendard, -apple-system, BlinkMacSystemFont,
					system-ui, sans-serif;
				background: var(--bg-main); color: var(--text-primary);
				min-height: 100vh; display: flex; align-items: center; justify-content: center;
				padding: 24px;
			}
			.card {
				background: var(--bg-surface); border: 1px solid var(--border);
				border-radius: var(--radius); padding: 56px 48px; text-align: center;
				box-shadow: var(--shadow); max-width: 440px; width: 100%;
			}
			.icon-wrap {
				width: 72px; height: 72px; border-radius: 50%;
				display: inline-flex; align-items: center; justify-content: center;
				font-size: 2rem; margin-bottom: 24px;
			}
			.accent-danger  { background: var(--color-danger-light);  color: var(--color-danger); }
			.accent-warning { background: var(--color-warning-light); color: var(--color-warning); }
			.accent-info    { background: var(--color-info-light);    color: var(--color-info); }
			.accent-primary { background: var(--color-primary-light); color: var(--color-primary); }
			.code {
				font-size: 0.78rem; font-weight: 700; letter-spacing: 0.12em;
				color: var(--text-secondary); text-transform: uppercase; margin-bottom: 8px;
			}
			h1 {
				font-size: 1.6rem; font-weight: 800; line-height: 1.3;
				letter-spacing: -0.02em; margin-bottom: 12px;
			}
			p.msg {
				color: var(--text-secondary); font-size: 0.95rem; line-height: 1.6;
				margin-bottom: 32px;
			}
			.actions { display: flex; gap: 8px; justify-content: center; flex-wrap: wrap; }
			.btn {
				display: inline-flex; align-items: center; gap: 6px;
				padding: 10px 20px; border-radius: 10px; font-size: 0.88rem; font-weight: 600;
				text-decoration: none; cursor: pointer; border: none; font-family: inherit;
				transition: opacity 0.15s, transform 0.1s;
			}
			.btn:hover { opacity: 0.9; }
			.btn:active { transform: translateY(1px); }
			.btn-primary { background: var(--color-primary); color: #fff; }
			.btn-ghost { background: transparent; color: var(--text-secondary); }
		</style>
	</head>
	<body>
		<main class="card">
			<div class={`icon-wrap accent-${accent}`}><i class={`bi ${icon}`}></i></div>
			<div class="code">{code}</div>
			<h1>{title}</h1>
			<p class="msg">{message}</p>
			<div class="actions">
				<a href="/" class="btn btn-primary">
					<i class="bi bi-house-door-fill"></i> 홈으로
				</a>
				<button class="btn btn-ghost" onclick="history.back()">
					<i class="bi bi-arrow-left"></i> 이전으로
				</button>
			</div>
		</main>
	</body>
</html>
