---
/**
 * ErrorLayout.astro — 4xx/5xx/offline 공용 레이아웃.
 * museum-finder 토큰 기반 중앙 배치 카드. body.mf-admin 스코프.
 * Props:
 *   - code: 에러 코드(401/403/404/500/OFFLINE)
 *   - title: 제목
 *   - message: 설명
 *   - icon: (레거시) Bootstrap 아이콘 이름 — 더 이상 사용하지 않음 (호환용 유지)
 *   - accent: 강조 토큰 ("danger" | "warning" | "info" | "primary")
 */
import BaseHead from "../components/BaseHead.astro";
import "../styles/tokens.css";
import "../styles/globals.css";

interface Props {
  code: string;
  title: string;
  message: string;
  icon?: string;
  accent?: "danger" | "warning" | "info" | "primary";
}

const { code, title, message, accent = "danger" } = Astro.props;
---

<html lang="ko">
  <head>
    <BaseHead title={`${code} · 카페 모니터`} description={title} />
  </head>
  <body class="mf-admin err">
    <main class="err__shell">
      <section class={`err__card err__card--${accent}`} role="alert" aria-live="polite">
        <div class="err__code">{code}</div>
        <h1 class="err__title">{title}</h1>
        <p class="err__msg">{message}</p>
        <div class="err__actions">
          <a class="err__btn err__btn--primary" href="/admin">대시보드로 돌아가기</a>
          <button class="err__btn err__btn--ghost" type="button" data-back>이전으로</button>
        </div>
      </section>
    </main>

    <style>
      body.err {
        background: var(--bg-soft);
        min-height: 100dvh;
        margin: 0;
      }
      .err__shell {
        min-height: 100dvh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 32px 16px;
      }
      .err__card {
        width: 100%;
        max-width: 440px;
        background: var(--bg-elev);
        border: 1px solid var(--border);
        border-top: 3px solid var(--border-strong);
        border-radius: var(--r-8);
        box-shadow: var(--shadow-md);
        padding: 40px 32px;
        text-align: center;
      }
      .err__card--danger { border-top-color: var(--danger); }
      .err__card--warning { border-top-color: var(--warning); }
      .err__card--info { border-top-color: var(--info); }
      .err__card--primary { border-top-color: var(--accent); }

      .err__code {
        font-size: var(--fs-28);
        font-weight: 700;
        color: var(--fg);
        letter-spacing: -0.02em;
        line-height: 1.1;
        font-family: var(--font-mono);
        margin-bottom: 12px;
      }
      .err__title {
        font-size: var(--fs-16);
        font-weight: 600;
        color: var(--fg);
        letter-spacing: -0.01em;
        margin: 0 0 8px 0;
      }
      .err__msg {
        font-size: var(--fs-13);
        color: var(--fg-muted);
        line-height: 1.55;
        margin: 0 0 24px 0;
      }
      .err__actions {
        display: flex;
        gap: 8px;
        justify-content: center;
        flex-wrap: wrap;
      }
      .err__btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
        height: 34px;
        padding: 0 14px;
        border-radius: var(--r-4);
        font-size: var(--fs-13);
        font-weight: 500;
        cursor: pointer;
        border: 1px solid transparent;
        font-family: inherit;
        text-decoration: none;
        transition: background 0.12s ease, border-color 0.12s ease;
      }
      .err__btn--primary {
        background: var(--accent);
        color: #fff;
        border-color: var(--accent);
      }
      .err__btn--primary:hover {
        background: var(--accent-hover);
        border-color: var(--accent-hover);
      }
      .err__btn--ghost {
        background: var(--bg-elev);
        color: var(--fg-muted);
        border-color: var(--border);
      }
      .err__btn--ghost:hover {
        background: var(--bg-hover);
        color: var(--fg);
      }
      @media (max-width: 480px) {
        .err__card { padding: 32px 20px; box-shadow: none; }
      }
    </style>

    <script>
      document.querySelector<HTMLButtonElement>('[data-back]')?.addEventListener('click', () => {
        if (window.history.length > 1) {
          window.history.back();
        } else {
          window.location.assign('/admin');
        }
      });
    </script>
  </body>
</html>
